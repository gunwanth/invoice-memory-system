{
  "name": "invoice-memory-backend",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
  "build": "tsc && npm run copy:schema",
  "copy:schema": "cpy \"src/db/schema.sql\" dist/db --parents",
  "start": "node dist/server.js",
  "demo": "node dist/demo/runDemo.js",
  "dev": "ts-node --transpile-only src/server.ts"
}
,
  "dependencies": {
    "better-sqlite3": "^9.4.0",
    "cors": "^2.8.5",
    "express": "^4.19.2",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "cpy-cli": "^6.0.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.4.0"
  }
}
